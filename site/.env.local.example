# Sanity — fill these in after creating a project (https://www.sanity.io/manage),
# then copy this file to .env.local. The Studio runs locally at /studio.
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-06-01"

# Optional: server-only read token for previewing drafts / private datasets.
# SANITY_API_READ_TOKEN=""
